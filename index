    <!-- Modal Detail Pembelian / Notifikasi Tengah (Opsional) -->
    
    <script>
        // ==========================================
        // 1. STATE & STORAGE MANAGEMENT
        // ==========================================
        const STORE_DORMS = 'wk_dorms';
        const STORE_TX = 'wk_tx';

        const Storage = {
            getDorms: () => JSON.parse(localStorage.getItem(STORE_DORMS) || '[]'),
            addDorm: (dormCode, token) => {
                let dorms = Storage.getDorms();
                let existing = dorms.find(d => d.code === dormCode);
                if(!existing) {
                    dorms.push({ code: dormCode, token: token, created_at: Date.now() });
                    localStorage.setItem(STORE_DORMS, JSON.stringify(dorms));
                    return { token, isNew: true };
                }
                return { token: existing.token, isNew: false };
            },
            getTx: () => JSON.parse(localStorage.getItem(STORE_TX) || '[]'),
            addTx: (tx) => {
                let txs = Storage.getTx();
                txs.unshift(tx); // Add to beginning
                localStorage.setItem(STORE_TX, JSON.stringify(txs));
                updateDashboard();
                renderHistory();
            },
            clearTx: () => {
                localStorage.setItem(STORE_TX, '[]');
                updateDashboard();
                renderHistory();
            }
        };

        // ==========================================
        // 2. AUDIO & HAPTIC FEEDBACK API
        // ==========================================
        const AudioFX = {
            ctx: null,
            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
            },
            playTone(freq, type, duration, vol=0.1) {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.type = type;
                osc.frequency.setValueAtTime(freq, this.ctx.currentTime);
                
                gain.gain.setValueAtTime(vol, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.0001, this.ctx.currentTime + duration);
                
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                
                osc.start();
                osc.stop(this.ctx.currentTime + duration);
            },
            success() {
                this.playTone(880, 'sine', 0.1, 0.2); // A5
                setTimeout(() => this.playTone(1760, 'sine', 0.2, 0.2), 100); // A6
                if(navigator.vibrate) navigator.vibrate([50, 50, 100]);
            },
            error() {
                this.playTone(300, 'sawtooth', 0.2, 0.2);
                setTimeout(() => this.playTone(250, 'sawtooth', 0.4, 0.3), 200);
                if(navigator.vibrate) navigator.vibrate([200, 100, 200]);
            }
        };

        // ==========================================
        // 3. UI/UX CONTROLS (TABS & TOAST)
        // ==========================================
        let currentTab = 'dashboard';
        
        function switchTab(tabId) {
            currentTab = tabId;
            
            // Hide all contents
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            // Show target content
            document.getElementById(tabId).classList.add('active');
            
            // Update mobile nav UI
            document.querySelectorAll('.nav-btn').forEach(el => {
                const isTarget = el.dataset.target === tabId;
                el.classList.toggle('text-white', isTarget);
                el.classList.toggle('text-apple-gray', !isTarget);
                
                // Specific styling for center scan button
                if(el.dataset.target === 'scan') {
                    const iconBg = el.querySelector('div');
                    if(isTarget) {
                        iconBg.classList.add('shadow-[0_0_20px_#0a84ff]');
                    } else {
                        iconBg.classList.remove('shadow-[0_0_20px_#0a84ff]');
                    }
                }
            });

            // Update desktop nav UI
            document.querySelectorAll('.nav-btn-desktop').forEach(el => {
                const isTarget = el.dataset.target === tabId;
                if(isTarget) {
                    el.classList.add('text-white', 'bg-white/10', 'shadow-sm');
                    el.classList.remove('text-apple-gray', 'hover:bg-white/5');
                } else {
                    el.classList.remove('text-white', 'bg-white/10', 'shadow-sm');
                    el.classList.add('text-apple-gray', 'hover:bg-white/5');
                }
            });

            // Camera logic: stop if not in scan tab
            if (tabId !== 'scan') {
                stopScanner();
            } else {
                // Initialize scan if switching to it, add a tiny delay for CSS transition
                setTimeout(initScanner, 300);
            }

            // Re-render icons for dynamic content if needed
            lucide.createIcons();
        }

        function showToast(title, message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            const isSuccess = type === 'success';
            const bgColor = isSuccess ? 'bg-apple-card' : 'bg-red-900/90';
            const borderColor = isSuccess ? 'border-green-500/30' : 'border-red-500/50';
            const iconColor = isSuccess ? 'text-apple-green' : 'text-white';
            const iconName = isSuccess ? 'check-circle-2' : 'alert-octagon';
            
            toast.className = `toast-enter ${bgColor} backdrop-blur-xl border ${borderColor} shadow-2xl rounded-2xl p-4 flex items-center gap-4 w-[90%] md:w-96 mb-2 pointer-events-auto`;
            toast.innerHTML = `
                <div class="${isSuccess ? 'bg-green-500/20' : 'bg-white/20'} p-2 rounded-full">
                    <i data-lucide="${iconName}" class="${iconColor} w-6 h-6"></i>
                </div>
                <div>
                    <h4 class="font-bold text-white text-sm">${title}</h4>
                    <p class="text-xs ${isSuccess ? 'text-gray-300' : 'text-red-100'}">${message}</p>
                </div>
            `;
            
            container.appendChild(toast);
            lucide.createIcons();
            
            // Trigger animation
            requestAnimationFrame(() => {
                toast.classList.add('toast-show');
            });

            // Remove after 3s
            setTimeout(() => {
                toast.classList.remove('toast-show');
                setTimeout(() => toast.remove(), 400);
            }, 4000);
        }

        // ==========================================
        // 4. DASHBOARD LOGIC
        // ==========================================
        function updateDashboard() {
            const txs = Storage.getTx();
            const dorms = Storage.getDorms();
            const now = Date.now();
            const startOfDay = new Date().setHours(0,0,0,0);
            
            // Basic Stats
            document.getElementById('stat-total-dorms').innerText = dorms.length;
            
            const todayScans = txs.filter(t => t.timestamp >= startOfDay).length;
            document.getElementById('stat-today-scans').innerText = todayScans;

            const limitReached = txs.filter(t => t.timestamp >= startOfDay && t.status === 'REJECTED').length;
            document.getElementById('stat-limit-reached').innerText = limitReached;

            // Recent Activity (Top 5)
            const recentContainer = document.getElementById('recent-activity-list');
            const recentTxs = txs.slice(0, 5);
            
            if (recentTxs.length === 0) {
                recentContainer.innerHTML = '<div class="text-center py-8 text-apple-gray text-sm">Belum ada aktivitas.</div>';
            } else {
                recentContainer.innerHTML = recentTxs.map(tx => {
                    const isSuccess = tx.status === 'SUCCESS';
                    const icon = isSuccess ? 'check' : 'x';
                    const color = isSuccess ? 'green' : 'red';
                    const timeStr = new Date(tx.timestamp).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'});
                    
                    return `
                    <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-colors border border-white/5">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-${color}-500/20 text-apple-${color} rounded-lg">
                                <i data-lucide="${icon}" class="w-4 h-4"></i>
                            </div>
                            <div>
                                <p class="font-bold text-white uppercase text-sm">${tx.code}</p>
                                <p class="text-xs text-apple-gray">${isSuccess ? 'Pengambilan Berhasil' : 'Limit Tercapai'}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-medium text-white">${timeStr}</p>
                        </div>
                    </div>`;
                }).join('');
                lucide.createIcons();
            }
        }

        // ==========================================
        // 5. GENERATE QR LOGIC
        // ==========================================
        let qrcodeInstances = []; // Store instances to manage them

        // UI Toggle Single/Bulk
        function setGenMode(mode) {
            const btnSingle = document.getElementById('btn-mode-single');
            const btnBulk = document.getElementById('btn-mode-bulk');
            const formSingle = document.getElementById('generate-form');
            const formBulk = document.getElementById('generate-bulk-form');

            if (mode === 'single') {
                btnSingle.className = 'px-6 py-2 rounded-lg text-sm font-bold bg-apple-blue text-white shadow-md transition-all';
                btnBulk.className = 'px-6 py-2 rounded-lg text-sm font-medium text-apple-gray hover:text-white transition-all';
                formSingle.classList.remove('hidden');
                formBulk.classList.add('hidden');
            } else {
                btnBulk.className = 'px-6 py-2 rounded-lg text-sm font-bold bg-apple-blue text-white shadow-md transition-all';
                btnSingle.className = 'px-6 py-2 rounded-lg text-sm font-medium text-apple-gray hover:text-white transition-all';
                formBulk.classList.remove('hidden');
                formSingle.classList.add('hidden');
            }
        }

        // Render Card Helper
        function createCardDOM(container, dormCode, token, isNew) {
            const cardId = `qr-target-${Math.random().toString(36).substr(2, 9)}`;
            const qrData = JSON.stringify({ c: dormCode, t: token });

            const div = document.createElement('div');
            div.className = "bg-white rounded-2xl p-5 text-black shadow-2xl border-4 border-gray-100 flex flex-col items-center relative overflow-hidden qr-card-print w-full max-w-[260px] mx-auto";
            
            let duplicateBadge = '';
            if(!isNew) {
                duplicateBadge = `<div class="absolute top-2 right-2 bg-yellow-100 text-yellow-800 text-[10px] font-bold px-2 py-1 rounded-full border border-yellow-300 z-10 shadow-sm uppercase tracking-widest">Sudah Ada</div>`;
            }

            div.innerHTML = `
                ${duplicateBadge}
                <!-- Top Accent -->
                <div class="absolute top-0 left-0 right-0 h-2 bg-gradient-to-r from-blue-500 to-cyan-400"></div>
                
                <h2 class="text-xl font-black tracking-tighter text-slate-800 mb-1 flex items-center gap-1 mt-1">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                    WATERKING
                </h2>
                <p class="text-[10px] font-bold text-gray-400 tracking-widest uppercase mb-4 border-b border-gray-200 pb-2 w-full text-center">Sistem Galon</p>
                
                <!-- QR Target -->
                <div id="${cardId}" class="bg-white p-2 rounded-xl shadow-inner border border-gray-100 mb-4" data-code="${dormCode}"></div>
                
                <div class="w-full text-center bg-gray-50 py-2 rounded-xl border border-gray-100">
                    <p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold mb-0.5">KODE ASRAMA</p>
                    <p class="text-3xl font-black text-blue-600 leading-none">${dormCode}</p>
                </div>
            `;
            container.appendChild(div);

            const qrcode = new QRCode(document.getElementById(cardId), {
                text: qrData,
                width: 140,
                height: 140,
                colorDark : "#000000",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });
            qrcodeInstances.push(qrcode);
        }

        function prepareQRContainer() {
            document.getElementById('qr-empty-state').classList.add('hidden');
            document.getElementById('qr-preview-container').classList.remove('hidden');
            const container = document.getElementById('printable-qr-area');
            container.innerHTML = '';
            qrcodeInstances = [];
            return container;
        }

        // Single Generate
        function handleGenerateQR(e) {
            e.preventDefault();
            const codeInput = document.getElementById('dorm-code-input');
            let dormCode = codeInput.value.trim().toUpperCase();
            
            if(!dormCode) return;

            const tempToken = Math.random().toString(36).substr(2, 9);
            const result = Storage.addDorm(dormCode, tempToken);
            
            const container = prepareQRContainer();
            createCardDOM(container, dormCode, result.token, result.isNew);

            updateDashboard();
            codeInput.value = '';
            showToast('QR Dibuat', `Kartu asrama ${dormCode} siap dicetak.`, 'success');
        }

        // Bulk Generate (Lazy Load Rendering)
        function handleGenerateBulkQR(e) {
            e.preventDefault();
            const textInput = document.getElementById('bulk-code-input');
            const lines = textInput.value.split('\n');
            const codes = [...new Set(lines.map(l => l.trim().toUpperCase()).filter(l => l !== ''))]; 

            if(codes.length === 0) return;

            const container = prepareQRContainer();
            let index = 0;
            let newCount = 0;
            let dupCount = 0;

            // Chunk rendering to avoid browser freeze
            function processChunk() {
                const limit = Math.min(index + 5, codes.length);
                for (; index < limit; index++) {
                    const dormCode = codes[index];
                    const tempToken = Math.random().toString(36).substr(2, 9);
                    const result = Storage.addDorm(dormCode, tempToken);
                    
                    if (result.isNew) newCount++;
                    else dupCount++;

                    createCardDOM(container, dormCode, result.token, result.isNew);
                }

                if (index < codes.length) {
                    setTimeout(processChunk, 50);
                } else {
                    updateDashboard();
                    textInput.value = '';
                    showToast('Bulk Generate Selesai', `Baru: ${newCount}, Sudah Ada: ${dupCount}`, 'success');
                }
            }

            processChunk();
        }

        function printAllQR() {
            window.print();
        }

        function downloadAllQR() {
            const canvases = document.querySelectorAll('#printable-qr-area canvas');
            if (canvases.length === 0) {
                showToast('Error', 'Tidak ada QR untuk didownload', 'error');
                return;
            }

            showToast('Mendownload', `Memproses ${canvases.length} gambar...`, 'success');
            
            let index = 0;
            // Delay for each download to prevent browser rate-limit
            function dlNext() {
                if (index >= canvases.length) return;
                
                const canvas = canvases[index];
                const codeNode = canvas.parentElement; 
                const code = codeNode.getAttribute('data-code') || `QR_${index}`;

                const image = canvas.toDataURL("image/png");
                const link = document.createElement('a');
                link.href = image;
                link.download = `QR_WATERKING_${code}.png`;
                link.click();

                index++;
                setTimeout(dlNext, 300);
            }
            dlNext();
        }

        // ==========================================
        // 6. QR SCANNER & 24H LIMIT LOGIC
        // ==========================================
        let html5QrcodeScanner = null;
        let isScanning = false;
        let lastScanData = null;
        let lastScanTime = 0;

        function check24HLimit(dormCode) {
            const txs = Storage.getTx();
            const now = Date.now();
            const twentyFourHours = 24 * 60 * 60 * 1000;
            
            // Count successful txs in last 24 hours for this dorm
            const recentTxs = txs.filter(tx => 
                tx.code === dormCode && 
                tx.status === 'SUCCESS' && 
                (now - tx.timestamp) < twentyFourHours
            );
            
            return recentTxs.length;
        }

        function onScanSuccess(decodedText, decodedResult) {
            // Prevent multiple rapid scans
            if (Date.now() - lastScanTime < 3000) return;
            lastScanTime = Date.now();

            try {
                // Expecting JSON {"c":"A03","t":"xyz"}
                const data = JSON.parse(decodedText);
                const dormCode = data.c;
                
                if(!dormCode) throw new Error("Format tidak valid");

                // Check limits
                const currentUsage = check24HLimit(dormCode);
                const limit = 2;

                if (currentUsage < limit) {
                    // SUCCESS
                    AudioFX.success();
                    Storage.addTx({
                        code: dormCode,
                        timestamp: Date.now(),
                        status: 'SUCCESS'
                    });
                    showToast('Pembelian Berhasil', `Asrama ${dormCode} - Pengambilan ke-${currentUsage + 1} hari ini.`, 'success');
                    
                    // Visual feedback
                    const viewport = document.querySelector('#reader');
                    viewport.style.boxShadow = 'inset 0 0 50px rgba(48, 209, 88, 0.5)';
                    setTimeout(() => viewport.style.boxShadow = 'none', 1000);

                } else {
                    // REJECTED
                    AudioFX.error();
                    Storage.addTx({
                        code: dormCode,
                        timestamp: Date.now(),
                        status: 'REJECTED'
                    });
                    showToast('Limit Harian Tercapai!', `Asrama ${dormCode} sudah mengambil 2x dalam 24 jam terakhir.`, 'error');
                    
                    const viewport = document.querySelector('#reader');
                    viewport.style.boxShadow = 'inset 0 0 50px rgba(255, 69, 58, 0.5)';
                    setTimeout(() => viewport.style.boxShadow = 'none', 1000);
                }

            } catch (e) {
                // Not JSON or invalid QR
                AudioFX.error();
                showToast('QR Tidak Dikenali', 'Pastikan scan QR resmi WaterKing.', 'error');
            }
        }

        function initScanner() {
            if (isScanning) return;
            
            document.getElementById('cam-status').innerText = "Memulai Kamera...";
            document.getElementById('scanner-indicator').classList.add('animate-pulse', 'bg-red-500');
            
            html5QrcodeScanner = new Html5Qrcode("reader");
            const config = { fps: 10, qrbox: { width: 250, height: 250 }, aspectRatio: 1.0 };
            
            html5QrcodeScanner.start({ facingMode: "environment" }, config, onScanSuccess)
                .then(() => {
                    isScanning = true;
                    document.getElementById('cam-status').innerText = "Kamera Aktif";
                    document.getElementById('cam-status').classList.replace('text-white', 'text-apple-green');
                    document.getElementById('scanner-indicator').classList.replace('bg-red-500', 'bg-apple-green');
                    document.getElementById('scanner-indicator').style.boxShadow = '0 0 10px rgba(48,209,88,0.8)';
                    
                    const icon = document.getElementById('icon-cam');
                    icon.setAttribute('data-lucide', 'video');
                    lucide.createIcons();
                })
                .catch((err) => {
                    document.getElementById('cam-status').innerText = "Gagal Akses Kamera";
                    document.getElementById('cam-status').classList.replace('text-apple-green', 'text-apple-red');
                    showToast('Akses Kamera', 'Mohon izinkan akses kamera untuk scan QR', 'error');
                });
        }

        function stopScanner() {
            if (html5QrcodeScanner && isScanning) {
                html5QrcodeScanner.stop().then(() => {
                    isScanning = false;
                    document.getElementById('cam-status').innerText = "Kamera Nonaktif";
                    document.getElementById('cam-status').classList.replace('text-apple-green', 'text-white');
                    document.getElementById('scanner-indicator').classList.replace('bg-apple-green', 'bg-red-500');
                    document.getElementById('scanner-indicator').style.boxShadow = '0 0 10px rgba(239,68,68,0.8)';
                    
                    const icon = document.getElementById('icon-cam');
                    icon.setAttribute('data-lucide', 'camera-off');
                    lucide.createIcons();
                }).catch(err => {
                    console.log("Error stopping scanner", err);
                });
            }
        }

        function toggleCamera() {
            if(isScanning) stopScanner();
            else initScanner();
        }

        // ==========================================
        // 7. HISTORY RENDERING
        // ==========================================
        function renderHistory() {
            const txs = Storage.getTx();
            const tbody = document.getElementById('history-table-body');
            const emptyState = document.getElementById('history-empty');

            if (txs.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            
            tbody.innerHTML = txs.map(tx => {
                const date = new Date(tx.timestamp);
                const dateStr = date.toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' });
                const timeStr = date.toLocaleTimeString('id-ID', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
                
                const isSuccess = tx.status === 'SUCCESS';
                const badgeClass = isSuccess ? 'bg-green-500/10 text-apple-green border-green-500/20' : 'bg-red-500/10 text-apple-red border-red-500/20';
                const statusText = isSuccess ? 'Sukses' : 'Ditolak';

                return `
                <tr class="hover:bg-white/5 transition-colors group">
                    <td class="py-4 px-6 border-b border-white/5">
                        <span class="font-bold text-white uppercase text-base">${tx.code}</span>
                    </td>
                    <td class="py-4 px-6 border-b border-white/5">
                        <div class="flex flex-col">
                            <span class="text-white text-sm">${dateStr}</span>
                            <span class="text-apple-gray text-xs">${timeStr}</span>
                        </div>
                    </td>
                    <td class="py-4 px-6 border-b border-white/5">
                        <span class="px-3 py-1 text-xs font-semibold rounded-full border ${badgeClass}">
                            ${statusText}
                        </span>
                    </td>
                </tr>`;
            }).join('');
        }

        function clearHistory() {
            if(confirm("Apakah Anda yakin ingin menghapus seluruh data histori?")) {
                Storage.clearTx();
                showToast('Histori Dihapus', 'Semua catatan transaksi telah dibersihkan', 'success');
            }
        }

        // ==========================================
        // 8. INITIALIZATION
        // ==========================================
        window.onload = () => {
            // Initialize Lucide Icons
            lucide.createIcons();
            
            // Unlock AudioContext on first interaction for Safari compatibility
            document.body.addEventListener('click', () => {
                AudioFX.init();
            }, { once: true });

            // Render Initial Data
            updateDashboard();
            renderHistory();
        };

    </script>
</body>
