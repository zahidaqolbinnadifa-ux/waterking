<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>WaterKing QR System</title>
    
    <!-- CDN Dependencies -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>

    <!-- Tailwind Config for Custom Theme -->
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['-apple-system', 'BlinkMacSystemFont', 'San Francisco', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'sans-serif'],
                    },
                    colors: {
                        glass: {
                            100: 'rgba(255, 255, 255, 0.1)',
                            200: 'rgba(255, 255, 255, 0.05)',
                            300: 'rgba(0, 0, 0, 0.2)',
                        },
                        apple: {
                            bg: '#000000',
                            card: '#1c1c1e',
                            blue: '#0a84ff',
                            green: '#30d158',
                            red: '#ff453a',
                            gray: '#8e8e93'
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.4s ease-out forwards',
                        'slide-up': 'slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        /* Custom Styles & Scrollbar */
        html, body {
            position: fixed;
            width: 100%;
            height: 100%;
            overflow: hidden;
            overscroll-behavior-y: none;
        }

        body {
            background-color: #000000;
            background-image: radial-gradient(circle at top right, #1a2a42 0%, #000000 40%),
                              radial-gradient(circle at bottom left, #0d1b2a 0%, #000000 40%);
            background-attachment: fixed;
            color: #ffffff;
            -webkit-tap-highlight-color: transparent;
        }
        
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.4); }

        .glass-card {
            background: rgba(28, 28, 30, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }

        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeIn 0.3s ease-in-out; }

        /* Print Style for QR Code */
        @media print {
            body * { visibility: hidden; }
            #printable-qr-area, #printable-qr-area * { visibility: visible; }
            #printable-qr-area {
                position: absolute;
                left: 0; top: 0; width: 100%; height: auto;
                display: grid !important;
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
                padding-top: 1cm;
                align-items: start;
                justify-items: center;
            }
            .qr-card-print {
                break-inside: avoid;
                page-break-inside: avoid;
                margin-bottom: 20px;
            }
            .no-print { display: none !important; }
        }

        /* Toast Animation */
        .toast-enter { transform: translateY(-100%); opacity: 0; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        .toast-show { transform: translateY(0); opacity: 1; }
    </style>
</head>
